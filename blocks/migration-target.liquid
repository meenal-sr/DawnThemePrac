{%- comment -%}
  Migration Target Block
  Creates a div with data-section-target attribute for content migration
{%- endcomment -%}

{%- if block.settings.section_id != blank -%}
  <div data-section-target="{{ block.settings.section_id }}" {{ block.shopify_attributes }}></div>
{%- endif -%}

{% schema %}
{
  "name": "Migration Target",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "Used for content migration targeting - multiple sections can append to this target"
    }
  ],
  "presets": [
    {
      "name": "Migration Target"
    }
  ]
}
{% endschema %}
