{
  "name": "module-update",
  "version": "1.0.0",
  "description": "TypeScript build with tree-shaken node_modules",
  "packageManager": "yarn@1.22.22",
  "private": true,
  "sideEffects": [
    "*.scss"
  ],
  "scripts": {
    "start": "tsc --noEmit && NODE_ENV=development webpack --watch",
    "lint": "eslint ts --ext .ts",
    "typecheck": "tsc --noEmit",
    "emit-declarations": "tsc --emitDeclarationOnly",
    "deploy": "webpack && shopify theme push",
    "shopify:push": "shopify theme push",
    "shopify:pull": "shopify theme pull -o 'templates/*.json'"
  },
  "main": "assets/main.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "typescript",
    "webpack",
    "tree-shaking"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "browserslist": [
    "last 2 versions",
    "not dead"
  ],
  "dependencies": {
    "@babel/runtime": "^7.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/plugin-transform-runtime": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "beeper": "^3.0.0",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "dotenv": "^16.3.1",
    "eslint": "^8.57.0",
    "eslint-webpack-plugin": "^5.0.3",
    "flowbite": "^4.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.0.0",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "postcss-preset-env": "^9.2.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "swiper": "^12.1.2",
    "tailwindcss": "^3.4.17",
    "terser-webpack-plugin": "^5.4.0",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-remove-empty-scripts": "^1.0.3",
    "webpack-shell-plugin-next": "^2.2.2",
    "webpack-sound-plugin": "^1.0.1"
  }
}
