<section class="tw-p-6 tw-bg-gray-100 tw-flex tw-flex-col tw-gap-8">

    <!-- ==========================
         MODAL BLOCK
         ========================== -->
    <div class="tw-bg-white tw-rounded tw-p-4 tw-shadow">
      <h3 class="tw-font-bold tw-mb-2">Modal Test</h3>
      <button data-modal-toggle="modal-test" class="tw-px-4 tw-py-2 tw-bg-blue-600 tw-text-white tw-rounded">
        Open Modal
      </button>
  
      <div id="modal-test" data-modal class="tw-hidden tw-fixed tw-inset-0 tw-flex tw-items-center tw-justify-center tw-z-[1050]">
        <div class="tw-bg-white tw-rounded tw-shadow-lg tw-p-6 tw-max-w-lg tw-w-full tw-relative">
          <h2 class="tw-text-lg tw-font-bold tw-mb-4">Modal Title</h2>
          <p class="tw-mb-4">This is the modal content. It has a backdrop and is fully accessible.</p>
          <div class="tw-flex tw-justify-end tw-space-x-2">
            <button data-modal-hide="modal-test" class="tw-bg-gray-300 tw-px-4 tw-py-2 tw-rounded">Close</button>
            <button data-modal-hide="modal-test" class="tw-bg-blue-600 tw-text-white tw-px-4 tw-py-2 tw-rounded">Accept</button>
          </div>
        </div>
      </div>
    </div>
  
    <!-- ==========================
         DRAWER BLOCK
         ========================== -->
    <div class="tw-bg-white tw-rounded tw-p-4 tw-shadow">
      <h3 class="tw-font-bold tw-mb-2">Drawer Test</h3>
      <button data-drawer-toggle="drawer-test" class="tw-px-4 tw-py-2 tw-bg-green-600 tw-text-white tw-rounded">
        Open Drawer
      </button>
  
      <div id="drawer-test" data-drawer class="tw-hidden tw-fixed tw-top-0 tw-left-0 tw-h-full tw-bg-white tw-shadow-xl tw-w-72 tw-transform tw-translate-x-[-100%] tw-transition-transform tw-duration-300 tw-ease-in-out tw-z-[1040]">
        <div class="tw-p-6">
          <h2 class="tw-text-lg tw-font-bold tw-mb-4">Drawer Content</h2>
          <p class="tw-mb-4">This is a left drawer with a backdrop and slide transition.</p>
          <button data-drawer-hide="drawer-test" class="tw-bg-gray-300 tw-px-4 tw-py-2 tw-rounded">Close Drawer</button>
        </div>
      </div>
    </div>
  
    <!-- ==========================
         POPOVER BLOCK
         ========================== -->
    <div class="tw-bg-white tw-rounded tw-p-4 tw-shadow tw-relative">
      <h3 class="tw-font-bold tw-mb-2">Popover Test</h3>
      <button data-popover-toggle="popover-test" class="tw-px-4 tw-py-2 tw-bg-purple-600 tw-text-white tw-rounded">
        Toggle Popover
      </button>
  
      <div id="popover-test" data-popover class="tw-hidden tw-absolute tw-bg-white tw-shadow-md tw-p-4 tw-rounded tw-z-[1060] tw-min-w-[200px]">
        <p>This is a popover. Click outside or press ESC to close.</p>
        <button data-popover-hide="popover-test" class="tw-bg-gray-300 tw-px-3 tw-py-1 tw-rounded tw-mt-2">Close</button>
      </div>
    </div>
  
    <!-- ==========================
         ACCORDION BLOCK
         ========================== -->
    <div class="tw-bg-white tw-rounded tw-p-4 tw-shadow">
      <h3 class="tw-font-bold tw-mb-2">Accordion Test</h3>
      <div data-accordion class="tw-border tw-border-gray-300 tw-rounded tw-bg-white">
        <button data-accordion-target="acc-panel1" aria-expanded="false" class="tw-w-full tw-text-left tw-p-4 tw-font-medium tw-border-b tw-border-gray-300">
          Accordion Item 1
        </button>
        <div id="acc-panel1" hidden class="tw-p-4">Content for accordion item 1.</div>
  
        <button data-accordion-target="acc-panel2" aria-expanded="false" class="tw-w-full tw-text-left tw-p-4 tw-font-medium tw-border-b tw-border-gray-300">
          Accordion Item 2
        </button>
        <div id="acc-panel2" hidden class="tw-p-4">Content for accordion item 2.</div>
      </div>
    </div>
  
    <!-- ==========================
         HORIZONTAL TABS BLOCK
         ========================== -->
    <div class="tw-bg-white tw-rounded tw-p-4 tw-shadow">
      <h3 class="tw-font-bold tw-mb-2">Horizontal Tabs Test</h3>
      <div data-tab-list class="tw-flex tw-border-b tw-border-gray-300 tw-bg-white tw-rounded">
        <button data-tab="tab1" data-tab-target="tab1-panel" aria-selected="true" class="tw-px-4 tw-py-2 tw-bg-blue-600 tw-text-white tw-rounded-tl tw-rounded-tr">
          Tab 1
        </button>
        <button data-tab="tab2" data-tab-target="tab2-panel" aria-selected="false" class="tw-px-4 tw-py-2 tw-bg-gray-200 tw-text-gray-900 tw-rounded-tl tw-rounded-tr">
          Tab 2
        </button>
      </div>
  
      <div id="tab1-panel" class="tw-p-4">
        <p>Content for horizontal Tab 1.</p>
      </div>
      <div id="tab2-panel" class="tw-hidden tw-p-4">
        <p>Content for horizontal Tab 2.</p>
      </div>
    </div>
  
    <!-- ==========================
         VERTICAL TABS BLOCK
         ========================== -->
    <div class="tw-bg-white tw-rounded tw-p-4 tw-shadow tw-flex tw-flex-col tw-gap-4">
      <h3 class="tw-font-bold tw-mb-2 tw-w-full">Vertical Tabs Test</h3>
      <div class="tw-flex tw-w-full">
        <div data-tab-list data-tab-orientation="vertical" class="tw-flex tw-flex-col tw-border-r tw-border-gray-300">
          <button data-tab="vtab1" data-tab-target="vtab1-panel" aria-selected="true" class="tw-px-4 tw-py-2 tw-bg-blue-600 tw-text-white">
            Vertical Tab 1
          </button>
          <button data-tab="vtab2" data-tab-target="vtab2-panel" aria-selected="false" class="tw-px-4 tw-py-2 tw-bg-gray-200 tw-text-gray-900">
            Vertical Tab 2
          </button>
        </div>
        <div class="tw-flex-1 tw-p-4">
          <div id="vtab1-panel">
            <p>Content for vertical Tab 1.</p>
          </div>
          <div id="vtab2-panel" class="tw-hidden">
            <p>Content for vertical Tab 2.</p>
          </div>
        </div>
      </div>
    </div>
  
  </section>

