{%- style -%}
  /* ========================================
     MOBILE BASE (<768px)
     ======================================== */
  .tenx-dontwait-{{ section.id }} {
    padding: 24px 16px;
    font-family: 'Montserrat', sans-serif;
  }

  .tenx-dontwait-{{ section.id }} .tenx-dontwait__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    max-width: 1356px;
    margin: 0 auto;
    min-height: 400px;
  }

  .tenx-dontwait-{{ section.id }} .tenx-dontwait__text {
    background-color: {{ section.settings.background_color }};
    border-radius: 40px 40px 40px 40px;
    padding: 60px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 43px;
  }

  .tenx-dontwait-{{ section.id }} .tenx-dontwait__heading {
    font-size: 36px;
    font-weight: 900;
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: normal;
  }

  .tenx-dontwait-{{ section.id }} .tenx-dontwait__image-wrapper {
    border-radius: 24px;
    overflow: hidden;
    min-height: 300px;
  }

  .tenx-dontwait-{{ section.id }} .tenx-dontwait__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tenx-dontwait-{{ section.id }} .tenx-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    padding: 11px 24px;
    transition: opacity 0.2s ease;
    cursor: pointer;
    line-height: 1.8;
  }

  .tenx-dontwait-{{ section.id }} .tenx-cta-button:hover {
    opacity: 0.85;
  }

  .tenx-dontwait-{{ section.id }} .tenx-cta-button--secondary {
    background-color: #d1242a;
    color: #ffffff;
    box-shadow: 0px 10px 20px rgba(209, 36, 42, 0.25);
  }

  /* ========================================
     TABLET (768px+)
     ======================================== */
  @media screen and (min-width: 768px) {
    .tenx-dontwait-{{ section.id }} {
      padding: 80px 42px;
    }

    .tenx-dontwait-{{ section.id }} .tenx-dontwait__grid {
      grid-template-columns: 2fr 1fr;
      gap: 40px;
      min-height: 540px;
    }

    .tenx-dontwait-{{ section.id }} .tenx-dontwait__text {
      border-radius: 40px 40px 40px 300px;
      padding: 161px 62px 149px;
    }

    .tenx-dontwait-{{ section.id }} .tenx-dontwait__heading {
      font-size: 54px;
    }

    .tenx-dontwait-{{ section.id }} .tenx-dontwait__image-wrapper {
      min-height: unset;
    }
  }

  /* ========================================
     DESKTOP (1024px+)
     ======================================== */
  @media screen and (min-width: 1024px) {
    .tenx-dontwait-{{ section.id }} {
      padding: {{ section.settings.padding_top }}px 42px {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="tenx-dontwait-{{ section.id }}" aria-label="{{ section.settings.heading | escape }}">
  <div class="tenx-dontwait__grid">
    <div class="tenx-dontwait__text">
      {%- if section.settings.heading != blank -%}
        <h2 class="tenx-dontwait__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        {% render '10x-cta-button',
          label: section.settings.cta_label,
          url: section.settings.cta_url,
          style: 'secondary'
        %}
      {%- endif -%}
    </div>
    <div class="tenx-dontwait__image-wrapper">
      {%- if section.settings.image != blank -%}
        <img
          class="tenx-dontwait__image"
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="437"
          height="540"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'tenx-dontwait__image' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "10X Don't Wait CTA",
  "tag": "section",
  "class": "section tenx-dont-wait-cta",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Don't Wait to Prioritize Your Health"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "ORDER MY GENETIC TEST"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1e1e1e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "10X Don't Wait CTA"
    }
  ]
}
{% endschema %}