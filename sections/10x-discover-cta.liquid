{%- style -%}
  /* ========================================
     MOBILE BASE (<768px)
     ======================================== */
  .tenx-discover-{{ section.id }} {
    padding: 24px 16px;
    font-family: 'Montserrat', sans-serif;
  }

  .tenx-discover-{{ section.id }} .tenx-discover__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1356px;
    margin: 0 auto;
  }

  .tenx-discover-{{ section.id }} .tenx-discover__card {
    background: #ffffff;
    border-radius: 40px;
    box-shadow: 0px 16px 20px rgba(0, 0, 0, 0.08);
    padding: 47px 32px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .tenx-discover-{{ section.id }} .tenx-discover__heading {
    font-size: 28px;
    font-weight: 900;
    line-height: 1.3;
    color: #28282a;
    margin: 0 0 15px;
  }

  .tenx-discover-{{ section.id }} .tenx-discover__body {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #28282a;
    margin: 0 0 32px;
  }

  .tenx-discover-{{ section.id }} .tenx-discover__body p {
    margin: 0;
  }

  .tenx-discover-{{ section.id }} .tenx-discover__image-wrapper {
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }

  .tenx-discover-{{ section.id }} .tenx-discover__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .tenx-discover-{{ section.id }} .tenx-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    padding: 14px 37px;
    min-width: 122px;
    max-width: 296px;
    transition: opacity 0.2s ease;
    cursor: pointer;
  }

  .tenx-discover-{{ section.id }} .tenx-cta-button:hover {
    opacity: 0.85;
  }

  .tenx-discover-{{ section.id }} .tenx-cta-button--primary {
    background-color: #1e1e1e;
    color: #ffffff;
    box-shadow: 0px 16px 20px rgba(0, 0, 0, 0.08);
  }

  .tenx-discover-{{ section.id }} .tenx-cta-button--secondary {
    background-color: #d1242a;
    color: #ffffff;
    box-shadow: 0px 10px 20px rgba(209, 36, 42, 0.25);
  }

  /* ========================================
     TABLET (768px+)
     ======================================== */
  @media screen and (min-width: 768px) {
    .tenx-discover-{{ section.id }} {
      padding: 40px 42px;
    }

    .tenx-discover-{{ section.id }} .tenx-discover__grid {
      grid-template-columns: 1.5fr 1fr;
      gap: 40px;
      align-items: center;
    }

    .tenx-discover-{{ section.id }} .tenx-discover__card {
      padding: 47px 56px 48px;
    }

    .tenx-discover-{{ section.id }} .tenx-discover__heading {
      font-size: 37.3px;
      line-height: 1.3;
    }

    .tenx-discover-{{ section.id }} .tenx-discover__body {
      font-size: 18px;
      line-height: 1.4;
    }
  }

  /* ========================================
     DESKTOP (1024px+)
     ======================================== */
  @media screen and (min-width: 1024px) {
    .tenx-discover-{{ section.id }} {
      padding: {{ section.settings.padding_top }}px 42px {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="tenx-discover-{{ section.id }}" aria-label="{{ section.settings.heading | escape }}">
  <div class="tenx-discover__grid{% if section.settings.layout_direction == 'image_first' %} tenx-discover__grid--reversed{% endif %}">
    <div class="tenx-discover__card">
      {%- if section.settings.heading != blank -%}
        <h2 class="tenx-discover__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body_text != blank -%}
        <div class="tenx-discover__body">{{ section.settings.body_text }}</div>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        {% render '10x-cta-button',
          label: section.settings.cta_label,
          url: section.settings.cta_url,
          style: 'primary'
        %}
      {%- endif -%}
    </div>
    <div class="tenx-discover__image-wrapper">
      {%- if section.settings.image != blank -%}
        <img
          class="tenx-discover__image"
          src="{{ section.settings.image | image_url: width: 1100 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="526"
          height="526"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'tenx-discover__image' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "10X Discover CTA",
  "tag": "section",
  "class": "section tenx-discover-cta",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover your body's deficiencies"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>It's time to decode your genes and discover which ones are functioning— and which ones aren't. Our genetic test gives you a comprehensive snapshot of your current health by analyzing key genes that directly impact your daily function.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Order My Genetic Test"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "layout_direction",
      "label": "Layout direction",
      "options": [
        { "value": "text_first", "label": "Text first" },
        { "value": "image_first", "label": "Image first" }
      ],
      "default": "text_first"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "10X Discover CTA"
    }
  ]
}
{% endschema %}