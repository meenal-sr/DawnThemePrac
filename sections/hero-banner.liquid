{%- comment -%}
  Hero Banner Section
  Full-width hero with background image and text overlay.
  Merchant-configurable content, background, and spacing.
  No JS required — static section.
{%- endcomment -%}

{%- liquid
  assign background_image = section.settings.background_image
  assign subtitle         = section.settings.subtitle
  assign heading          = section.settings.heading
  assign description      = section.settings.description
  assign button_text      = section.settings.button_text
  assign button_link      = section.settings.button_link
  assign overlay_opacity  = section.settings.overlay_opacity
  assign content_max_width = section.settings.content_max_width
  assign pt_desktop       = section.settings.padding_top_desktop
  assign pb_desktop       = section.settings.padding_bottom_desktop
  assign pt_mobile        = section.settings.padding_top_mobile
  assign pb_mobile        = section.settings.padding_bottom_mobile
-%}

<style>
  #shopify-section-{{ section.id }} .hero-banner {
    padding-top: {{ pt_mobile }}px;
    padding-bottom: {{ pb_mobile }}px;
  }
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .hero-banner {
      padding-top: {{ pt_desktop }}px;
      padding-bottom: {{ pb_desktop }}px;
    }
  }
  #shopify-section-{{ section.id }} .hero-banner__container {
    max-width: {{ content_max_width }}px;
  }
</style>

<section
  class="hero-banner tw-relative tw-overflow-hidden tw-w-full"
  aria-label="{{ heading | escape }}"
>

  {%- comment -%} Background image {%- endcomment -%}
  <div class="hero-banner__bg tw-absolute tw-inset-0 tw-w-full tw-h-full">
    {%- if background_image != blank -%}
      {%- liquid
        assign img_url  = background_image | image_url: width: 1920
        assign img_url_mobile = background_image | image_url: width: 800
        assign img_aspect = background_image.width | divided_by: background_image.height | times: 1.0
        assign img_alt  = background_image.alt | default: heading | escape
      -%}
      <picture>
        <source
          media="(min-width: 1024px)"
          srcset="
            {{ background_image | image_url: width: 1200 }} 1200w,
            {{ background_image | image_url: width: 1920 }} 1920w
          "
        >
        <source
          srcset="
            {{ background_image | image_url: width: 600 }} 600w,
            {{ background_image | image_url: width: 800 }} 800w
          "
        >
        <img
          class="hero-banner__bg-img tw-absolute tw-inset-0 tw-w-full tw-h-full tw-object-cover"
          src="{{ img_url }}"
          alt="{{ img_alt }}"
          loading="eager"
          fetchpriority="high"
        >
      </picture>
    {%- endif -%}
  </div>

  {%- comment -%} Optional dark overlay {%- endcomment -%}
  {%- if overlay_opacity > 0 -%}
    <div
      class="hero-banner__overlay tw-absolute tw-inset-0"
      style="background-color: rgba(0,0,0,{{ overlay_opacity | divided_by: 100.0 }});"
      aria-hidden="true"
    ></div>
  {%- endif -%}

  {%- comment -%} Content container {%- endcomment -%}
  <div class="hero-banner__container tw-relative tw-z-10 tw-mx-auto tw-px-5 tw-w-full">
    <div class="hero-banner__inner tw-flex tw-flex-col tw-gap-4">

      {%- if subtitle != blank -%}
        <p class="hero-banner__subtitle tw-text-white tw-text-[13px] md:tw-text-[16px] tw-font-medium tw-uppercase tw-tracking-[0.52px] tw-m-0">
          {{ subtitle | escape }}
        </p>
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="hero-banner__heading tw-text-white tw-text-[32px] md:tw-text-[60px] tw-font-bold tw-leading-tight md:tw-leading-[66px] tw-m-0">
          {{ heading | escape }}
        </h2>
      {%- endif -%}

      {%- if description != blank -%}
        <div class="hero-banner__description tw-text-white tw-text-[16px] tw-leading-normal tw-opacity-70">
          {{ description }}
        </div>
      {%- endif -%}

      {%- if button_text != blank -%}
        <a
          href="{{ button_link | default: '#' }}"
          class="hero-banner__cta tw-inline-block tw-self-start tw-bg-[#027db3] tw-text-white tw-text-[16px] tw-font-bold tw-rounded-full tw-px-8 tw-py-[14px] tw-no-underline tw-leading-none tw-transition-colors"
        >
          {{ button_text | escape }}
        </a>
      {%- endif -%}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle label",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unlock Exclusive Savings"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Get contractor pricing on top HVAC brands. Limited time deals on AC units, heat pumps, and more.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 600,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "label": "Content max width",
      "default": 938
    },
    {
      "type": "header",
      "content": "Spacing — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding (desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (desktop)",
      "default": 32
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding (mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding (mobile)",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
