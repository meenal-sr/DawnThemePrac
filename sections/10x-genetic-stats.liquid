{%- style -%}
  /* ========================================
     MOBILE BASE (<768px)
     ======================================== */
  .tenx-stats-{{ section.id }} {
    padding: 24px 16px;
    font-family: 'Montserrat', sans-serif;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__card {
    background: #ffffff;
    border-radius: 32px;
    box-shadow: 0px 16px 20px rgba(0, 0, 0, 0.08);
    padding: 40px 24px;
    max-width: 1356px;
    margin: 0 auto;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__headline {
    font-size: 22px;
    font-weight: 800;
    color: #28282a;
    text-align: center;
    margin: 0 0 16px;
    line-height: 1.3;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__subheading {
    font-size: 16px;
    font-weight: 400;
    color: #28282a;
    text-align: center;
    margin: 0 0 24px;
    line-height: 1.4;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__symptoms {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin: 0 0 40px;
    padding: 0 16px;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__symptom {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__symptom-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__symptom-text {
    font-size: 18px;
    font-weight: 800;
    color: #28282a;
    line-height: normal;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__body {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #28282a;
    padding: 0 16px;
    margin: 0 0 40px;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__body p {
    margin: 0 0 24px;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__body p:last-child {
    margin-bottom: 0;
  }

  .tenx-stats-{{ section.id }} .tenx-stats__cta-wrapper {
    text-align: center;
    padding: 40px 0 0;
  }

  .tenx-stats-{{ section.id }} .tenx-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    padding: 14px 37px;
    min-width: 122px;
    transition: opacity 0.2s ease;
    cursor: pointer;
  }

  .tenx-stats-{{ section.id }} .tenx-cta-button:hover {
    opacity: 0.85;
  }

  .tenx-stats-{{ section.id }} .tenx-cta-button--primary {
    background-color: #1e1e1e;
    color: #ffffff;
    box-shadow: 0px 16px 20px rgba(0, 0, 0, 0.08);
  }

  /* ========================================
     TABLET (768px+)
     ======================================== */
  @media screen and (min-width: 768px) {
    .tenx-stats-{{ section.id }} {
      padding: 40px 42px;
    }

    .tenx-stats-{{ section.id }} .tenx-stats__card {
      padding: 40px 120px;
    }

    .tenx-stats-{{ section.id }} .tenx-stats__headline {
      font-size: 28px;
    }

    .tenx-stats-{{ section.id }} .tenx-stats__symptoms {
      grid-template-columns: 1fr 1fr;
      padding: 0;
    }

    .tenx-stats-{{ section.id }} .tenx-stats__body {
      font-size: 18px;
      line-height: 1.4;
      padding: 0;
    }
  }

  /* ========================================
     DESKTOP (1024px+)
     ======================================== */
  @media screen and (min-width: 1024px) {
    .tenx-stats-{{ section.id }} {
      padding: {{ section.settings.padding_top }}px 42px {{ section.settings.padding_bottom }}px;
    }

    .tenx-stats-{{ section.id }} .tenx-stats__headline {
      font-size: 31px;
    }

    .tenx-stats-{{ section.id }} .tenx-stats__symptoms {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    .tenx-stats-{{ section.id }} .tenx-stats__symptom-text {
      font-size: 22px;
    }
  }
{%- endstyle -%}

<section class="tenx-stats-{{ section.id }}" aria-label="Genetic mutation statistics">
  <div class="tenx-stats__card">
    {%- if section.settings.headline != blank -%}
      <h2 class="tenx-stats__headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="tenx-stats__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="tenx-stats__symptoms">
        {%- for block in section.blocks -%}
          {%- if block.type == 'symptom' -%}
            <div class="tenx-stats__symptom" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <img
                  class="tenx-stats__symptom-icon"
                  src="{{ block.settings.icon | image_url: width: 48 }}"
                  alt=""
                  aria-hidden="true"
                  width="24"
                  height="24"
                  loading="lazy"
                >
              {%- else -%}
                <svg class="tenx-stats__symptom-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" fill="#28282a"/>
                </svg>
              {%- endif -%}
              <span class="tenx-stats__symptom-text">{{ block.settings.text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <div class="tenx-stats__body">{{ section.settings.body_text }}</div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="tenx-stats__cta-wrapper">
        {% render '10x-cta-button',
          label: section.settings.cta_label,
          url: section.settings.cta_url,
          style: 'primary'
        %}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "10X Genetic Stats",
  "tag": "section",
  "class": "section tenx-genetic-stats",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "44% OF THE WORLD'S population has this genetic mutation"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Most common symptoms of a Nutrient Deficiency:"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Are you ready to find out the truth about your body? This could be your chance to uncover what's really going on inside. But first, let's talk about something you might not know…</p><p>Did you know that a staggering 44% of the world's population has a genetic mutation that makes it tough for them to create enough of the 5-MTHFR gene? In layman's terms this means that your body may not be functioning as it should. The methylation cycle is a crucial process that your body goes through to convert raw nutrients into usable forms that your body needs.</p><p>This process is essential for everything from detoxification to energy production, hormone balance, and maintaining proper immune and nervous system function. But here's the kicker — it's not just one gene that can cause issues. There are actually five main genes that could be mutated, preventing your body from functioning optimally and depriving it of essential nutrients.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "ORDER MY GENETIC TEST"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "symptom",
      "name": "Symptom",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Symptom text"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "10X Genetic Stats",
      "blocks": [
        { "type": "symptom", "settings": { "text": "Anxiety" } },
        { "type": "symptom", "settings": { "text": "Depression" } },
        { "type": "symptom", "settings": { "text": "ADD/ADHD" } },
        { "type": "symptom", "settings": { "text": "OCD" } },
        { "type": "symptom", "settings": { "text": "Gut Issues" } },
        { "type": "symptom", "settings": { "text": "Weight Management" } },
        { "type": "symptom", "settings": { "text": "Brain Fog" } },
        { "type": "symptom", "settings": { "text": "Thyroid Problem" } },
        { "type": "symptom", "settings": { "text": "High Blood Pressure" } },
        { "type": "symptom", "settings": { "text": "Bad Temper" } },
        { "type": "symptom", "settings": { "text": "And so much more..." } }
      ]
    }
  ]
}
{% endschema %}